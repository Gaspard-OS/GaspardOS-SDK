/* ELF 32 bits x86, entrée = gmain */
ENTRY(global_gmain)

SECTIONS
{
  
    . = 0x0; 

    .text ALIGN(16) : {
        *(.text .text.*)
        *(.init)
        *(.fini)
    }

    .rodata ALIGN(16) : {
        *(.rodata .rodata.*)
        *(.rodata1)
    }

    .data ALIGN(16) : {
        *(.data .data.*)
    }

    .bss ALIGN(16) : {
        __bss_start = .;
        *(.bss .bss.*)
        *(COMMON)
        __bss_end = .;
    }
}
